# HTTP
HTTP_HOST=
HTTP_PORT=8080

METRICS_HOST=
METRICS_PORT=9090

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_DATABASE=manage_task
MYSQL_MAX_OPEN_CONNS=25
MYSQL_MAX_IDLE_CONNS=25
MYSQL_CONN_MAX_LIFETIME=5m

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
# Пул соединений (0 => дефолты go-redis: PoolSize=10*GOMAXPROCS, без min idle / max lifetime)
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=0
REDIS_CONN_MAX_LIFETIME=0

# JWT
JWT_SECRET=dev-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Logger
LOG_LEVEL=info
LOG_PATH=logs/app.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=28

# Rate limiting (per-user, fixed window) на защищённых ручках
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# Email (mock sender) — приглашения в команду отправляются best-effort
EMAIL_ENABLED=true
EMAIL_FAIL_PERCENT=0
EMAIL_LATENCY=50ms

# Circuit breaker для исходящего email
CB_MAX_FAILURES=5
CB_OPEN_TIMEOUT=30s
CB_HALF_OPEN_MAX=1
